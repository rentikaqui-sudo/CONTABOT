# ContaBot — Variables de entorno requeridas
# Copiar este archivo como .env y completar los valores

# Flask — generar con: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=CAMBIAR-genera-con-secrets-token-hex-32

# Supabase
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=CAMBIAR-genera-con-secrets-token-hex-16

# Google / Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cifrado de refresh tokens OAuth (opcional pero recomendado en producción)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Entorno (development | production)
FLASK_ENV=development
